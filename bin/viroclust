#!/usr/bin/env python3
"""
ViroClust command-line interface wrapper.

Usage:
    viroclust -f input.fasta -c input.clstr -o output_dir [options]
"""

import sys
import os

# Add parent directory to path so we can import from src
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__)))))

from bin.viroclust import main

if __name__ == '__main__':
    main()
